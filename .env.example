# Modèle de configuration — copiez ce fichier en `.env` et renseignez vos valeurs.
# Django
DJANGO_SECRET_KEY=remplacez-par-une-cle-secrete
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Base de données PostgreSQL
DB_NAME=finances_niger
DB_USER=finances_user
DB_PASSWORD=votre_mot_de_passe
DB_HOST=127.0.0.1
DB_PORT=5432

# CORS — origines autorisées (le frontend Next.js)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
